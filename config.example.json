{
  "port": 3000,
  "webhookSecret": "ENV:GITHUB_WEBHOOK_SECRET",
  "kiroPath": "/path/to/kiro",
  "defaultGithubToken": "ENV:GITHUB_TOKEN",
  "rateLimit": {
    "perPRSeconds": 60
  },
  "sessionTimeout": {
    "inactivityMinutes": 5,
    "maxLifetimeMinutes": 120,
    "gracePeriodAfterMergeSeconds": 60
  },
  "repos": [
    {
      "owner": "your-org",
      "name": "your-repo"
    },
    {
      "owner": "your-org",
      "name": "another-repo",
      "token": "ENV:GH_TOKEN_ANOTHER_REPO",
      "webhookSecret": "ENV:WEBHOOK_SECRET_ANOTHER_REPO"
    }
  ],
  "cron": []
}
